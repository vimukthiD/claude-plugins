{
  "name": "wikijs-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Wiki.js - manage pages via GraphQL API",
  "private": true,
  "type": "module",
  "main": "server/index.cjs",
  "scripts": {
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node18 --outfile=server/index.cjs",
    "typecheck": "tsc --noEmit",
    "start": "node server/index.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "esbuild": "0.28.1",
    "typescript": "5.9.3"
  }
}
